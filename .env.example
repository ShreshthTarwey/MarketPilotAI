# MarketPilot AI Server Configuration
# Copy this file to '.env' in this directory (or the root directory) and fill in your API keys.

# Server Settings
PORT=5000
NODE_ENV=development

# API Keys (Get these from Google AI Studio, Tavily AI, and Groq Console)
GEMINI_API_KEY=your_gemini_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# Groq API Key Pool (Supports multiple rotated keys)
GROQ_API_KEY_1=your_groq_api_key_1_here
GROQ_API_KEY_2=your_groq_api_key_2_here
GROQ_API_KEY_3=your_groq_api_key_3_here
GROQ_API_KEY_4=your_groq_api_key_4_here

# Agent & Cache Rules
CACHE_TTL_MS=3600000
MAX_RECOLLECTION_ATTEMPTS=2
